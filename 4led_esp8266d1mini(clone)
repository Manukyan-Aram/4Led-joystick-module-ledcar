#include <espnow.h>
#include <ESP8266WiFi.h>

// LED փիները
const int d1 = D1;
const int d2 = D2;
const int d3 = D3;
const int d4 = D4;

typedef struct struct_message {
  bool l1, l2, l3, l4, l5, l6, l7, l8, l9;
} struct_message;

struct_message incomingData;

void onDataRecv(uint8_t * mac, uint8_t *incomingBytes, uint8_t len) {
  memcpy(&incomingData, incomingBytes, sizeof(incomingData));

  if (incomingData.l1) { //forward
    analogWrite(d1, 0); analogWrite(d2, 1023); 
    analogWrite(d3, 1023);    analogWrite(d4, 0);
  } 
  else if (incomingData.l2) { //backward
    analogWrite(d1, 1023);    analogWrite(d2, 0); 
    analogWrite(d3, 0); analogWrite(d4, 1023);
  }
  else if (incomingData.l3) {  //right 
    analogWrite(d1, 0); analogWrite(d2, 200); 
    analogWrite(d3, 0); analogWrite(d4, 200);
  }
  else if (incomingData.l4) { //left
    analogWrite(d1, 200);   analogWrite(d2, 0); 
    analogWrite(d3, 200);   analogWrite(d4, 0);
  }
  else if (incomingData.l5) { //for right
    analogWrite(d1, 0); analogWrite(d2, 1023);
    analogWrite(d3, 100);    analogWrite(d4, 0);
  }
  else if (incomingData.l6) { //for left
    analogWrite(d1, 0);   analogWrite(d2, 100);
    analogWrite(d3, 1023);   analogWrite(d4, 0);
  }
  else if (incomingData.l7) { //back right
    analogWrite(d1, 1023); analogWrite(d2, 0);
    analogWrite(d3, 0);    analogWrite(d4, 100);
  }
  else if (incomingData.l8) { //back left
    analogWrite(d1, 100);   analogWrite(d2, 0);
    analogWrite(d3, 0);   analogWrite(d4, 1023);
  }
  else if (incomingData.l9) {
    analogWrite(d1, 0); analogWrite(d2, 0); 
    analogWrite(d3, 0); analogWrite(d4, 0);
  }
}

void setup() {
  WiFi.mode(WIFI_STA);
  if (esp_now_init() != 0) return;

  pinMode(d1, OUTPUT);
  pinMode(d2, OUTPUT);
  pinMode(d3, OUTPUT);
  pinMode(d4, OUTPUT);

  esp_now_set_self_role(ESP_NOW_ROLE_SLAVE);
  esp_now_register_recv_cb(onDataRecv);
}

void loop() {
}
