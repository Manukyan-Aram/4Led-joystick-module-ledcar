#include <esp_now.h>
#include <WiFi.h>

uint8_t broadcastAddress[] = { 0x24, 0x4C, 0xAB, 0x48, 0x78, 0x9F };

const int pot1 = 34;  // x
const int pot2 = 35;  // y

typedef struct struct_message {
  bool l1, l2, l3, l4, l5, l6, l7, l8, l9;
} struct_message;

struct_message myData;
struct_message lastData; // Նախորդ վիճակը պահելու համար
esp_now_peer_info_t peerInfo;

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);

  if (esp_now_init() != ESP_OK) return;

  memcpy(peerInfo.peer_addr, broadcastAddress, 6);
  peerInfo.channel = 1; // Հստակ ալիք սահմանելը խնայում է էներգիան
  peerInfo.encrypt = false;
  if (esp_now_add_peer(&peerInfo) != ESP_OK) return;
}

void loop() {
  int x = analogRead(pot1);
  int y = analogRead(pot2);

  myData.l1 = myData.l2 = myData.l3 = myData.l4 = myData.l5 = myData.l6 = myData.l7 = myData.l8 = myData.l9 = false;

  if (y > 3500 && (x > 1800 && x < 2200)) myData.l1 = true; //forward
  else if (y < 500 && (x > 1800 && x < 2200)) myData.l2 = true; //backward
  else if (x > 3500 && (y > 1700 && y < 2300)) myData.l3 = true;  //right
  else if (x < 500 && (y > 1700 && y < 2300)) myData.l4 = true;  //left
  else if (x > 3500 && y > 3500) myData.l5 = true; //for right
  else if (x < 500 && y > 3500) myData.l6 = true; //for left
  else if (x > 3500 && y < 500) myData.l7 = true; //back right
  else if (x < 500 && y < 500) myData.l8 = true; //back left
  else if (x > 1200 && x < 2800 && y > 1200 && y < 2800) myData.l9 = true;

  // Ուղարկել միայն եթե տվյալը փոխվել է
  if (memcmp(&myData, &lastData, sizeof(myData)) != 0) {
    esp_now_send(broadcastAddress, (uint8_t *)&myData, sizeof(myData));
    memcpy(&lastData, &myData, sizeof(myData)); // Թարմացնում ենք վերջին վիճակը
  }

  delay(50); // Տալիս ենք պրոցեսորին հանգստանալու ժամանակ
}
